{
  "name": "secure-doc-admin",
  "version": "0.1.5",
  "description": "Offline secure document issuer and viewer using WebCrypto and 6-15 character PINs",
  "author": "Secure Doc Team",
  "main": "out/main/main.js",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/install-electron-runtime.mjs",
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "test": "node --test --experimental-strip-types tests/*.test.ts",
    "fix:electron": "node scripts/install-electron-runtime.mjs",
    "make:mac": "npm run build && electron-builder --mac dmg --universal",
    "make:win": "npm run build && electron-builder --win nsis --x64"
  },
  "dependencies": {
    "@tiptap/react": "^3.23.1",
    "@tiptap/starter-kit": "^3.23.1",
    "nodemailer": "^8.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.0.0",
    "electron-vite": "^4.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "com.company.securedoc.admin",
    "productName": "Secure Doc Admin",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "sign": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
